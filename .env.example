# ─────────────────────────────────────────────
# AVA Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# App
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this

# Database (auto-set by docker-compose)
DATABASE_URL=postgresql+asyncpg://ava:ava_password@localhost:5432/ava_db

# JWT
JWT_SECRET=your-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── FREE AI KEYS ──────────────────────────────
# Groq (fast reasoning + Whisper STT) — free at console.groq.com
GROQ_API_KEY=gsk_...

# Gemini 1.5 Flash (long context + files) — free at aistudio.google.com
GEMINI_API_KEY=AIza...

# ── VOICE ────────────────────────────────────
# ElevenLabs (human voice TTS) — 10k chars/mo free at elevenlabs.io
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── TOOLS ────────────────────────────────────
# Tavily (web search) — 1k/mo free at tavily.com
TAVILY_API_KEY=tvly-...

# E2B (code sandbox) — free tier at e2b.dev
E2B_API_KEY=e2b_...

# ── VECTOR MEMORY ────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── NEXT.JS ──────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-this
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── GOOGLE CLOUD (for deployment) ────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=ava-file-storage

# Optional Phase 2 Additions
